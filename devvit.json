{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "ramageddon-game",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      }
    }
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create RAMAGEDDON post",
        "description": "Create a new RAMAGEDDON Daily Wreckpile post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "marketingAssets": {
    "icon": "assets/app-icon.png"
  },
  "sourceIgnores": ["public/", "Vampire Survivors by poncle_files/"],
  "dev": {
    "subreddit": "ramageddon_game_dev"
  }
}
